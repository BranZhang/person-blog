---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import { slugifyStr } from "@/utils/slugify";
import { toTransitionName } from "@/utils/toTransitionName";
import Datetime from "./Datetime.astro";
import Tag from "./Tag.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, cover, tags, ...props } = data;
const visibleTags = tags.slice(0, 3);
const hiddenTagCount = tags.length - visibleTags.length;

// Fade the cover in from the left so it blends into the card instead of
// showing a hard edge next to the text.
const coverMask = "linear-gradient(to right, transparent, black 45%)";
---

<li class="my-2">
  <div
    class:list={[
      "group hover:bg-muted/60 relative overflow-hidden rounded-xl px-4 py-5 transition-colors duration-200",
      cover ? "h-44 lg:h-52" : "h-40 lg:h-44",
    ]}
  >
    <div class="flex h-full items-start gap-4 overflow-hidden">
      <div class="flex h-full min-w-0 flex-1 flex-col overflow-hidden">
        <a
          href={getPostUrl(id, filePath, Astro.currentLocale)}
          class:list={[
            "text-accent inline-block text-lg font-medium",
            "decoration-dashed underline-offset-4 group-hover:underline",
            "focus-visible:no-underline focus-visible:underline-offset-0",
            "after:absolute after:inset-0 after:rounded-xl",
          ]}
        >
          <Heading
            class="line-clamp-2"
            transition:name={toTransitionName(title)}
          >
            {title}
          </Heading>
        </a>
        <Datetime {...props} />
        <p
          class:list={[cover ? "line-clamp-1 lg:line-clamp-2" : "line-clamp-1"]}
        >
          {description}
        </p>
        {
          visibleTags.length > 0 && (
            <ul class="relative z-10 mt-auto flex max-h-6 shrink-0 flex-wrap items-start gap-x-3 overflow-hidden">
              {visibleTags.map(tag => (
                <Tag
                  tag={slugifyStr(tag)}
                  tagName={tag}
                  size="sm"
                  transitionName={false}
                />
              ))}
              {hiddenTagCount > 0 && (
                <li class="border-border bg-muted/60 text-foreground flex h-6 items-center rounded-md border px-2 text-xs font-medium tabular-nums">
                  +{hiddenTagCount}
                </li>
              )}
            </ul>
          )
        }
      </div>
      {
        cover && (
          <div class="relative hidden h-full w-56 shrink-0 overflow-hidden sm:block lg:w-72">
            <img
              src={cover}
              alt=""
              loading="lazy"
              class="absolute inset-0 h-full w-full object-cover"
              style={`mask-image:${coverMask};-webkit-mask-image:${coverMask}`}
            />
          </div>
        )
      }
    </div>
  </div>
</li>
