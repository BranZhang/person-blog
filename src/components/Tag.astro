---
import { getRelativeLocaleUrl } from "astro:i18n";
import IconHash from "@/assets/icons/IconHash.svg";
import config from "@/config";

type Props = {
  tag: string;
  tagName: string;
  postCount?: number;
  size?: "sm" | "lg";
  transitionName?: boolean;
};

const {
  tag,
  tagName,
  postCount,
  size = "lg",
  transitionName = true,
} = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
---

<li>
  <a
    href={getRelativeLocaleUrl(locale, `tags/${tag}/`)}
    transition:name={transitionName ? tag : undefined}
    class:list={[
      "inline-flex items-center gap-1.5 rounded-md border transition-colors",
      "focus-visible:border-accent focus-visible:text-accent focus-visible:outline-2 focus-visible:outline-offset-2",
      {
        "border-border bg-muted/30 hover:border-accent/60 hover:bg-muted/70 w-full justify-between px-3 py-2":
          postCount !== undefined,
      },
      {
        "border-border bg-muted/60 hover:border-accent/60 hover:bg-accent/10 hover:text-accent h-6 px-2":
          postCount === undefined && size === "sm",
      },
      {
        "border-border bg-muted/50 hover:border-accent/60 hover:bg-accent/10 hover:text-accent px-3 py-1.5":
          postCount === undefined && size === "lg",
      },
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <span class="flex min-w-0 items-center gap-0.5">
      <IconHash
        class:list={[
          "text-accent shrink-0 opacity-80",
          { "size-5": size === "lg" },
          { "size-4": size === "sm" },
        ]}
      />
      <span class="truncate">{tagName}</span>
    </span>
    {
      postCount !== undefined && (
        <span class="border-border bg-background/80 text-muted-foreground ms-3 min-w-7 shrink-0 rounded-sm border px-1.5 py-0.5 text-center text-sm font-semibold tabular-nums">
          {postCount}
        </span>
      )
    }
  </a>
</li>
