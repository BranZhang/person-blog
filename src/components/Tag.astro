---
import { getRelativeLocaleUrl } from "astro:i18n";
import IconHash from "@/assets/icons/IconHash.svg";
import config from "@/config";

type Props = {
  tag: string;
  tagName: string;
  postCount?: number;
  size?: "sm" | "lg";
};

const { tag, tagName, postCount, size = "lg" } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
---

<li>
  <a
    href={getRelativeLocaleUrl(locale, `tags/${tag}/`)}
    transition:name={tag}
    class:list={[
      "flex items-center gap-0.5",
      "border-foreground border-b-2 border-dashed",
      "hover:border-accent hover:text-accent hover:-mt-0.5",
      "focus-visible:text-accent focus-visible:border-none",
      { "w-full justify-between py-2": postCount !== undefined },
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <span class="flex min-w-0 items-center gap-0.5">
      <IconHash
        class:list={[
          "shrink-0 opacity-80",
          { "size-5": size === "lg" },
          { "size-4": size === "sm" },
        ]}
      />
      <span class="truncate">{tagName}</span>
    </span>
    {
      postCount !== undefined && (
        <span class="text-muted-foreground ms-3 min-w-6 shrink-0 text-right text-sm font-medium tabular-nums">
          {postCount}
        </span>
      )
    }
  </a>
</li>
