---
import type { ImageMetadata } from "astro";
import { Image as AstroImage } from "astro:assets";

// Responsive image gallery carried over from the old WordPress gallery blocks.
// Relative content paths are resolved to local image metadata and processed by
// astro:assets.
type Image = { src: string; alt?: string; caption?: string };

type Props = {
  images: Image[];
  /** Min column width in px; grid auto-fits as many columns as fit. */
  min?: number;
  caption?: string;
};

const { images, min = 220, caption } = Astro.props;

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/content-images/**/*.{avif,gif,jpeg,jpg,png,svg,webp}",
  { eager: true }
);

function resolveImage(source: string): ImageMetadata {
  const marker = "assets/content-images/";
  const markerIndex = source.indexOf(marker);
  if (markerIndex === -1) {
    throw new Error(
      `Gallery image must be under src/assets/content-images: ${source}`
    );
  }

  const encodedSuffix = source.slice(markerIndex + marker.length);
  let suffix = encodedSuffix;
  try {
    suffix = decodeURIComponent(encodedSuffix);
  } catch {
    // Keep the original path so the error below identifies the bad reference.
  }

  const key = `/src/assets/content-images/${suffix}`;
  const image = imageModules[key]?.default;
  if (!image) throw new Error(`Could not resolve Gallery image: ${source}`);
  return image;
}
---

<figure class="blog-gallery">
  <div
    class="blog-gallery-grid"
    style={`grid-template-columns:repeat(auto-fit,minmax(${min}px,1fr))`}
  >
    {
      images.map(image => (
        <figure class="blog-gallery-item">
          <div class="blog-gallery-image">
            <AstroImage
              src={resolveImage(image.src)}
              alt={image.alt ?? image.caption ?? ""}
              loading="lazy"
              layout="full-width"
            />
          </div>
          {image.caption && <figcaption>{image.caption}</figcaption>}
        </figure>
      ))
    }
  </div>
  {caption && <figcaption class="blog-gallery-caption">{caption}</figcaption>}
</figure>
