---
import { Image } from "astro:assets";
import { BASE } from "../config.ts";

const { image } = Astro.props;

// A public/ absolute path (e.g. "/wp-content/uploads/.../cover.avif") is served
// as-is. This supports any format (avif/webp/…) and matches how the migrated
// post bodies reference their images.
const isPublicPath = image.startsWith("/") && !image.startsWith("/src/");

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif}"
);

// replace ../.. with src in image
let replacedImage = image.replace("../..", "/src");

if (!isPublicPath && !images[replacedImage])
  throw new Error(
    `"${replacedImage}" does not exist in glob: "src/assets/**/*.{jpeg,jpg,png,gif}"`
  );

const resolved = isPublicPath ? null : images[replacedImage];

// The cover is shown complete (object-contain) so wide/tall images aren't
// cropped, over a blurred, zoomed copy of the same image that fills the empty
// space — keeping every card the same shape without letterbox gaps.
const bgClass =
  "absolute inset-0 h-full w-full object-cover scale-110 blur-2xl";
const fgClass = "absolute inset-0 h-full w-full object-contain";
---

<div
  class="absolute inset-0 overflow-hidden rounded-2xl bg-base-100 dark:bg-base-900"
>
  {
    isPublicPath ? (
      <Fragment>
        <img src={BASE + image} alt="" aria-hidden="true" class={bgClass} />
        <img src={BASE + image} alt="" loading="lazy" class={fgClass} />
      </Fragment>
    ) : (
      <Fragment>
        <Image src={resolved!()} alt="" aria-hidden="true" class={bgClass} />
        <Image src={resolved!()} alt="" class={fgClass} />
      </Fragment>
    )
  }
</div>

<div
  class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-base-900/10 dark:ring-base-100/10"
>
</div>
