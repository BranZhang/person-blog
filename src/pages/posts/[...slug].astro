---
import { type CollectionEntry, render } from "astro:content";
import BaseLayout from "$layouts/BaseLayout.astro";
import BlogPost from "$layouts/BlogPost.astro";
import Header from "$components/Header.astro";
import Footer from "$components/Footer.astro";
import { Image } from "astro:assets";
import FormattedDate from "$components/FormattedDate.astro";
import { getBlogPosts } from "src/utils";
import Giscus from "$components/Giscus.astro";
import Tag from "$components/Tag.astro";
import { BASE, SHOW_IMAGES } from "../../config.ts";

export async function getStaticPaths() {
  const posts = await getBlogPosts(true);
  return posts.map((post: any) => ({
    params: { slug: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await render(post);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif}"
);
const hero = post.data.heroImage;
// A public/ absolute path (e.g. "/wp-content/uploads/.../cover.avif") is served
// as-is and supports any format; other paths resolve against /src/assets.
const heroIsPublic = !!hero && hero.startsWith("/") && !hero.startsWith("/src/");
const replacedHero = heroIsPublic ? undefined : hero?.replace("../..", "/src");
if (replacedHero && !images[replacedHero])
  throw new Error(
    `"${hero}" does not exist in glob: "src/assets/**/*.{jpeg,jpg,png,gif}"`
  );
const showHero =
  !!hero && post.data.hideHero !== true && SHOW_IMAGES;
---

<BaseLayout {...post.data} image={post.id + ".png"}>
  <Header active="blog" />

  <main class="max-w-2xl lg:max-w-3xl mx-auto my-0 h-full p-4">
    {
      showHero ? (
        heroIsPublic ? (
          <img
            src={BASE + hero}
            alt=""
            class="w-full h-80 object-cover rounded-xl shadow border border-base-400 dark:border-base-700"
          />
        ) : (
          <Image
            src={images[replacedHero!]()}
            alt=""
            class="w-full h-80 object-cover rounded-xl shadow border border-base-400 dark:border-base-700"
          />
        )
      ) : null
    }
    <BlogPost>
      <div
        class="flex mt-8 gap-4 text-xs flex-col md:flex-row items-start md:items-center"
      >
        <div class="shrink-0">
          <FormattedDate date={post.data.pubDate} />
        </div>
        <div class="flex gap-2 flex-wrap">
          {post.data.tags?.map((tag: string) => <Tag {tag} />)}
        </div>
      </div>

      <h1 class="mt-4">{post.data.title}</h1>
      <Content />
      <Giscus />
    </BlogPost>
  </main>
  <Footer />
</BaseLayout>
